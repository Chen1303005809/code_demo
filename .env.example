# ── 上游 LightRag 配置（docker compose 会读取本文件）──────────────
# 拷贝为 .env 后按需修改：cp .env.example .env

# LightRag 服务地址（必填，不含 /query/stream，代码会自动拼接）
#   - LightRag 跑在宿主机  ：http://host.docker.internal:9621
#   - LightRag 同在 compose ：http://<服务名>:9621
LLM_API_URL=http://host.docker.internal:9621

# Bearer Token（可选，LightRag 如不需要则留空）
LLM_API_KEY=

# 查询模式：mix / hybrid / local / global / naive
LLM_QUERY_MODE=mix

# 单次请求超时（毫秒）
LLM_TIMEOUT_MS=60000

# 并发槽位数
MAX_CONCURRENCY=3

# 注：DB_PATH 在 docker-compose.yml 中固定为 /app/data/history.db，无需在此设置。
